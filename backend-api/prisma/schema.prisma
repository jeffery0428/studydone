generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String?
  role         UserRole       @default(student)
  checkQuota   Int            @default(30)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  reports      Report[]
  subscriptions Subscription[]
  reservations CreditReservation[]
  humanReviews HumanReviewRequest[]
}

model Report {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName         String
  fileType         String
  fileStorageKey   String
  overallScore     Float
  rawText          String?  @db.LongText
  segmentResults   Json
  bibliographyScan Json?    // GPTZero /v2/bibliography-scan/text 返回结果
  detectorVendor   String   @default("gptzero")
  creditsUsed      Int      @default(0)  // 本次检测消耗积分
  createdAt        DateTime @default(now())
}

model Subscription {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSessionId String?  @unique
  plan            String
  checkQuota      Int
  createdAt       DateTime @default(now())
}

model CreditReservation {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  status    ReservationStatus @default(reserved)
  taskId    String            @unique
  expiresAt DateTime
  createdAt DateTime          @default(now())

  @@index([userId, status, expiresAt])
}

model HumanReviewRequest {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName       String
  fileType       String
  ossObjectKey   String
  charCount      Int
  creditsUsed    Int
  status         HumanReviewStatus @default(pending)
  createdAt      DateTime          @default(now())
  completedAt    DateTime?
}

enum HumanReviewStatus {
  pending
  in_progress
  completed
  cancelled
}

enum UserRole {
  student
  teacher
}

enum ReservationStatus {
  reserved
  committed
  cancelled
}

