NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=https://studydone.vip

DATABASE_URL=mysql://root:password@127.0.0.1:3306/studydone
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=7d

R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret
R2_BUCKET=studydone-files
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=

GPTZERO_API_KEY=your_gptzero_key
GPTZERO_BASE_URL=https://api.gptzero.me
GPTZERO_ENDPOINT=/v2/predict/text

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# 生产环境请填写 Stripe Dashboard 中创建的固定 Price ID；仅开发环境允许缺省后回退到代码内金额
STRIPE_PRICE_5=price_xxx
STRIPE_PRICE_50=price_xxx
STRIPE_PRICE_200=price_xxx
FRONTEND_APP_URL=https://studydone.vip

